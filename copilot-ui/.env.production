# Même origine que le site Vercel : le navigateur appelle /webhook/… puis Vercel relaie vers n8n (voir vercel.json à la racine).
# Évite CORS « Failed to fetch » par rapport aux URL https:// n8n directes.

VITE_API_LOGIN=/webhook/login
VITE_API_REFRESH=/webhook/refresh
VITE_API_LOGOUT=/webhook/logout
VITE_API_ME=/webhook/me

VITE_API_RH_USERS_LIST=/webhook/rh/users
VITE_API_RH_USERS_CREATE=/webhook/rh/users
VITE_API_RH_USERS_ROLE=/webhook/rh/users/role
VITE_API_RH_USERS_STATUS=/webhook/rh/users/status
VITE_API_RH_USERS_PASSWORD_RESET_BASE=/webhook/rh/users
VITE_API_RH_SESSIONS=/webhook/rh/sessions
