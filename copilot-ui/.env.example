# ---------------------------------------------------------------------------
# Copie vers `.env`. Soit des URL complètes par webhook n8n, soit une seule
# VITE_API_BASE_URL + chemins relatifs dans le code.
# Contrat API attendu par le front : voir docs/BRIEF-BACKEND-COLLEGUE.md
# ---------------------------------------------------------------------------

# Option A — une base (ex. https://host/webhook) : login = {base}/login, etc.
# VITE_API_BASE_URL=

# Option B — URL complète par endpoint n8n (prioritaire sur A)
# VITE_API_LOGIN=
# VITE_API_REFRESH=
# VITE_API_LOGOUT=
# VITE_API_ME=
# VITE_API_RH_USERS_LIST=
# VITE_API_RH_USERS_CREATE=
# VITE_API_RH_USERS_ROLE=
# VITE_API_RH_USERS_STATUS=
# Base pour PATCH …/rh/users/{id}/password-reset (sans /{id}/password-reset à la fin)
# VITE_API_RH_USERS_PASSWORD_RESET_BASE=
# VITE_API_RH_SESSIONS=

# Copilot (optionnel)
# VITE_COPILOT_API_BASE=
